# --- Neo4j (knowledge graph) ---
NEO4J_URI=bolt://localhost:7687 # Bolt URI used by the Neo4j Python driver
NEO4J_USER=neo4j # Neo4j username used for authentication
NEO4J_PASSWORD=your_neo4j_password_here # Neo4j password used for authentication

# --- Groq (transcription and text cleanup) ---
GROQ_API_KEY=your_groq_api_key_here # API key for Groq speech/text endpoints

# --- EdenAI (LLM reasoning) ---
EDENAI_API_KEY=your_edenai_api_key_here # API key for EdenAI LLM calls
EDENAI_MODEL=openai/gpt-4o # EdenAI model identifier used for completions
